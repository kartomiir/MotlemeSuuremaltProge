        drive_base.settings(straight_speed=350, straight_acceleration=400)
        drive_base.straight(200)
        drive_base.turn(4)
        drive_base.straight(85)  # Finishes pushing the boat
        tool_right.run(800)  # Yellow thingymajig down to pull red thingymajig back.
        tool_left.run(800)  # Puts flag down
        wait(615)
        tool_left.stop()
        wait(25)  # Yellow keeps going
        tool_right.stop()
        drive_base.turn(-10)
        drive_base.settings(straight_speed=200, straight_acceleration=200)
        drive_base.straight(-78)
        tool_right.run(-800)
        wait(570)
        tool_right.stop()
        drive_base.settings(straight_speed=800, straight_acceleration=800)
        drive_base.settings(turn_rate=750, turn_acceleration=800)
        drive_base.turn(8)
        drive_base.straight(-50)
        drive_base.turn(-42)  # Align for M10.
        tool_left.run(-800)
        wait(540)
        tool_left.stop()
        drive_base.straight(695)
        tool_left.run(800)  # Basket.
        wait(570)
        tool_left.stop()
        drive_base.straight(-183)  
        drive_base.turn(60)
        drive_base.settings(turn_rate=300, turn_acceleration=150)
        drive_base.straight(156)
        drive_base.settings(straight_speed=1089, straight_acceleration=2000)
        drive_base.turn(-33)  # Turns into scale pan
        drive_base.turn(18)
        drive_base.straight(-22)  # Goes backwards to align the robots turning path with the pan
        drive_base.turn(30)
        drive_base.turn(-20)
        drive_base.straight(800)  # Back to base

def fourth():  # M09, M07, M11
    """
    if tool_left.run() < 0 it goes the CORRECT way, spinning clockwise.
    """
    drive_base.straight(157)
    wait(150)  # Waits so the formula FL can drive
    drive_base.straight(-50)
    drive_base.turn(75)
    drive_base.straight(100)
    drive_base.turn(-30)  # Aligns with M09
    drive_base.straight(288)
    tool_left.run(300)  # Knocks red pin down
    wait(800)
    tool_left.stop()
    drive_base.straight(34)  # Goes further so the long stick can go behind the roof
    drive_base.settings(straight_speed=300, straight_acceleration=200)
    drive_base.straight(-395)  # Pulls roof back
    drive_base.turn(-28)
    drive_base.settings(straight_speed=800, straight_acceleration=500)
    drive_base.settings(turn_rate=500, turn_acceleration=400)
    left_motor.run(800)
    right_motor.run(800)
    tool_left.run(-300)  # Tool out of the way
    wait(800)
    tool_left.stop()
    left_motor.stop()
    right_motor.stop()
    drive_base.turn(5)  # Slight turn to avoid pushing the artifact backwards
    left_motor.run(400)
    right_motor.run(400)
    wait(1000)
    left_motor.stop()
    right_motor.stop()
    drive_base.turn(-22)  # Gets behind the artifact rope
    drive_base.straight(-66)
    drive_base.turn(45)  # Lets go of the artifact
    drive_base.straight(-110)
    drive_base.turn(-20)
    drive_base.settings(straight_speed=1089, straight_acceleration=1200)
    drive_base.straight(-650)

